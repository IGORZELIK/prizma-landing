---
interface Props {
  t: Record<string, any>;
}
const { t } = Astro.props;

const formats = [
  { label: t.modules.items[0].name, color: '#8B5CF6' },
  { label: t.modules.items[1].name, color: '#06B6D4' },
  { label: t.modules.items[2].name, color: '#10B981' },
  { label: t.modules.items[3].name, color: '#F59E0B' },
  { label: t.modules.items[4].name, color: '#EC4899' },
  { label: t.modules.items[5].name, color: '#6366F1' },
];

// Single SVG canvas: 800 x 360
// Prism transform: translate(50, 95) scale(0.9)
// Original prism right-junction point (150,90) maps to:
// x = 50 + 150*0.9 = 185,  y = 95 + 90*0.9 = 176
const originX = 185;
const originY = 176;

// 6 badge positions (right side), evenly distributed
const badgeX = 590;
const badgeH = 44;
const badgeGap = 12;
const totalH = 6 * badgeH + 5 * badgeGap;  // 324
const startY = (360 - totalH) / 2;           // 18

const badges = formats.map((f, i) => ({
  ...f,
  bx: badgeX,
  by: startY + i * (badgeH + badgeGap),
  cy: startY + i * (badgeH + badgeGap) + badgeH / 2,
}));
---

<section class="visual-demo" id="visual-demo">
  <div class="section-wrap">
    <h2 class="reveal">{t.visual_demo.heading}</h2>

    <div class="scene-wrap">
      <svg
        class="prism-scene"
        viewBox="0 0 800 360"
        preserveAspectRatio="xMidYMid meet"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <defs>
          <radialGradient id="prismGlow" cx="50%" cy="50%" r="50%">
            <stop offset="0%"  stop-color="#8B5CF6" stop-opacity="0.3"/>
            <stop offset="50%" stop-color="#06B6D4" stop-opacity="0.1"/>
            <stop offset="100%" stop-color="transparent" stop-opacity="0"/>
          </radialGradient>
          <filter id="dropGlow" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur in="SourceGraphic" stdDeviation="8" result="blur"/>
            <feMerge>
              <feMergeNode in="blur"/>
              <feMergeNode in="SourceGraphic"/>
            </feMerge>
          </filter>
        </defs>

        <!-- Prism ambient glow -->
        <circle cx={originX} cy={originY} r="110" fill="url(#prismGlow)" opacity="0.7"/>

        <!-- Glow rays (thick, soft) -->
        {badges.map((b, i) => (
          <line
            class="ray-glow"
            x1={originX} y1={originY}
            x2={b.bx} y2={b.cy}
            stroke={b.color}
            stroke-width="8"
            opacity="0.2"
            style={`--ray-delay: ${i * 0.15}s;`}
          />
        ))}

        <!-- Sharp rays -->
        {badges.map((b, i) => (
          <line
            class="ray-line"
            x1={originX} y1={originY}
            x2={b.bx} y2={b.cy}
            stroke={b.color}
            stroke-width="1.5"
            style={`--ray-delay: ${i * 0.15}s;`}
          />
        ))}

        <!-- Prism triangles (on top of rays via z-order) -->
        <g transform="translate(50, 95) scale(0.9)" filter="url(#dropGlow)">
          <polygon points="100,5 50,90 150,90"   fill="#8B5CF6"/>
          <polygon points="5,175 50,90 100,175"   fill="#06B6D4"/>
          <polygon points="195,175 150,90 100,175" fill="#10B981"/>
        </g>

        <!-- Badge backgrounds -->
        {badges.map((b) => (
          <rect
            class="badge-rect"
            x={b.bx} y={b.by}
            width="190" height={badgeH}
            rx="12"
            fill="rgba(255,255,255,0.04)"
            stroke="rgba(255,255,255,0.09)"
            stroke-width="1"
            style={`--badge-delay: ${1.0 + badges.indexOf(b) * 0.12}s; --accent: ${b.color};`}
          />
        ))}

        <!-- Badge dots -->
        {badges.map((b) => (
          <circle cx={b.bx + 22} cy={b.cy} r="5" fill={b.color}
            class="badge-dot-svg"
            style={`--badge-delay: ${1.0 + badges.indexOf(b) * 0.12}s;`}
          />
        ))}

        <!-- Badge labels -->
        {badges.map((b) => (
          <text
            class="badge-text"
            x={b.bx + 38} y={b.cy + 5}
            font-family="Outfit, sans-serif"
            font-size="15"
            font-weight="500"
            fill="#F1F1F3"
            style={`--badge-delay: ${1.0 + badges.indexOf(b) * 0.12}s;`}
          >
            {b.label}
          </text>
        ))}
      </svg>
    </div>
  </div>
</section>

<style>
  .visual-demo {
    position: relative;
    z-index: 1;
  }

  .visual-demo h2 {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 40px;
  }

  .scene-wrap {
    max-width: 900px;
    margin: 0 auto;
  }

  .prism-scene {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Ray animation */
  .ray-line,
  .ray-glow {
    stroke-dasharray: 700;
    stroke-dashoffset: 700;
    animation: drawRay 2s ease-out var(--ray-delay, 0s) forwards;
  }

  @keyframes drawRay {
    to { stroke-dashoffset: 0; }
  }

  /* Badge fade-in */
  .badge-rect,
  .badge-dot-svg,
  .badge-text {
    opacity: 0;
    animation: fadeIn 0.5s ease-out var(--badge-delay, 1s) forwards;
  }

  @keyframes fadeIn {
    to { opacity: 1; }
  }

  .badge-rect:hover {
    fill: rgba(255,255,255,0.08);
    stroke: var(--accent);
  }
</style>

<script>
  // Replay animation on scroll into view
  const scene = document.querySelector('.prism-scene');
  if (scene) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          scene.querySelectorAll('.ray-line, .ray-glow, .badge-rect, .badge-dot-svg, .badge-text').forEach(el => {
            const clone = el.cloneNode(true) as Element;
            el.parentNode?.replaceChild(clone, el);
          });
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });
    observer.observe(scene);
  }
</script>
