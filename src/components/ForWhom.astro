---
interface Props {
  t: Record<string, any>;
}
const { t } = Astro.props;
if (!t.for_whom) return;

const icons = [
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
];
const colors = ['#8B5CF6', '#06B6D4', '#10B981', '#F59E0B'];
---

<section class="for-whom">
  <div class="section-wrap">
    <h2 class="reveal">{t.for_whom.heading}</h2>
    <div class="whom-grid" data-stagger>
      {t.for_whom.items.map((item: any, i: number) => (
        <div class="whom-card glass-card" style={`--accent: ${colors[i]};`}>
          <div class="whom-icon" set:html={icons[i]} />
          <div class="whom-title">{item.title}</div>
          <div class="whom-desc">{item.desc}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .whom-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-top: 60px;
  }

  .whom-card {
    padding: 36px 32px;
    position: relative;
    border-left: 2px solid var(--accent);
    transition: box-shadow 0.3s, background 0.3s;
  }

  .whom-card:hover {
    background: rgba(255,255,255,0.06);
    box-shadow: 0 8px 40px rgba(0,0,0,0.3), 0 0 30px color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .whom-icon {
    color: var(--accent);
    margin-bottom: 16px;
  }

  .whom-title {
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--text-primary);
    margin-bottom: 10px;
  }

  .whom-desc {
    font-size: 0.9rem;
    color: var(--text-dim, #6B7280);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .whom-grid { grid-template-columns: 1fr; }
  }
</style>
