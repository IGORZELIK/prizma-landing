---
interface Props {
  size?: number;
}
const { size = 220 } = Astro.props;
---

<div class="prism-container" style={`width:${size}px;height:${Math.round(size * 0.9)}px;`}>
  <svg class="prism-svg" viewBox="0 0 200 180" fill="none" xmlns="http://www.w3.org/2000/svg">
    <polygon class="tri-top" points="100,5 50,90 150,90" fill="#8B5CF6"/>
    <polygon class="tri-left" points="5,175 50,90 100,175" fill="#06B6D4"/>
    <polygon class="tri-right" points="195,175 150,90 100,175" fill="#10B981"/>
  </svg>
</div>

<style>
  .prism-container {
    position: relative;
    margin-bottom: 48px;
    filter: drop-shadow(0 0 60px rgba(139, 92, 246, 0.3));
  }

  .prism-svg { width: 100%; height: 100%; }

  .tri-top, .tri-left, .tri-right { opacity: 0; }

  .tri-top    { animation: flyTop    1s cubic-bezier(0.16,1,0.3,1) 0.5s forwards; }
  .tri-left   { animation: flyLeft   1s cubic-bezier(0.16,1,0.3,1) 0.8s forwards; }
  .tri-right  { animation: flyRight  1s cubic-bezier(0.16,1,0.3,1) 1.1s forwards; }

  @keyframes flyTop {
    from { opacity: 0; transform: translateY(-80px) scale(0.5) rotate(-15deg); }
    to   { opacity: 1; transform: translateY(0) scale(1) rotate(0); }
  }
  @keyframes flyLeft {
    from { opacity: 0; transform: translate(-80px, 60px) scale(0.5) rotate(15deg); }
    to   { opacity: 1; transform: translate(0, 0) scale(1) rotate(0); }
  }
  @keyframes flyRight {
    from { opacity: 0; transform: translate(80px, 60px) scale(0.5) rotate(-15deg); }
    to   { opacity: 1; transform: translate(0, 0) scale(1) rotate(0); }
  }
  /* Pulsing glow */
  .prism-container::after {
    content: '';
    position: absolute;
    inset: -30px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.15), transparent 70%);
    opacity: 0;
    animation: pulseGlow 3s ease-in-out 2.2s infinite;
    pointer-events: none;
  }

  @keyframes pulseGlow {
    0%, 100% { opacity: 0.3; transform: scale(0.95); }
    50%      { opacity: 0.7; transform: scale(1.1); }
  }

  @media (max-width: 600px) {
    .prism-container {
      width: 160px !important;
      height: 144px !important;
    }
  }
</style>
