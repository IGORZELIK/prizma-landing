---
interface Props {
  t: Record<string, any>;
}
const { t } = Astro.props;
---

<section class="demo-section" id="demo">
  <div class="section-wrap">
    <h2 class="reveal">{t.demo.heading}</h2>

    <div class={`demo-player glass-card reveal${t.lang !== 'ru' ? ' demo-coming-soon' : ''}`}>
      <div class="demo-backdrop"></div>
      <div class="demo-grid-lines"></div>
      {t.lang === 'ru' ? (
        <div class="play-btn">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="#fff">
            <path d="M8 5v14l11-7z"/>
          </svg>
        </div>
      ) : (
        <div class="coming-soon-overlay">
          <div class="coming-soon-icon">🎬</div>
          <div class="coming-soon-label">
            {t.lang === 'de' ? 'Demnächst verfügbar' : 'Coming soon'}
          </div>
          <div class="coming-soon-sub">
            {t.lang === 'de' ? 'Video in Ihrer Sprache wird vorbereitet' : 'Video in your language is on its way'}
          </div>
        </div>
      )}
    </div>

    <p class="demo-caption">{t.demo.caption}</p>
  </div>
</section>

<style>
  .demo-section {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .demo-section h2 {
    margin-bottom: 48px;
  }

  .demo-player {
    max-width: 900px;
    margin: 0 auto;
    overflow: hidden;
    position: relative;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 0;
  }

  .demo-player:hover {
    border-color: rgba(139, 92, 246, 0.3);
    box-shadow:
      0 0 80px rgba(139, 92, 246, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  .demo-backdrop {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.08), rgba(6, 182, 212, 0.05), rgba(16, 185, 129, 0.03));
  }

  .demo-grid-lines {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  .play-btn {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--purple), var(--purple-deep));
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
    box-shadow: 0 0 60px rgba(139, 92, 246, 0.4);
    transition: transform 0.3s;
  }

  .play-btn svg {
    margin-left: 4px;
  }

  .demo-player:hover .play-btn {
    transform: scale(1.1);
  }

  .demo-coming-soon {
    cursor: default;
  }

  .demo-coming-soon:hover {
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: none;
  }

  .coming-soon-overlay {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .coming-soon-icon {
    font-size: 2.5rem;
    opacity: 0.6;
  }

  .coming-soon-label {
    font-family: 'Unbounded', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .coming-soon-sub {
    font-size: 0.85rem;
    color: var(--text-dim);
  }

  .demo-caption {
    margin-top: 20px;
    font-size: 0.85rem;
    color: var(--text-dim);
  }
</style>
