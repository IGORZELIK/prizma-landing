---
interface Props {
  t: Record<string, any>;
}
const { t } = Astro.props;

const phases = [
  {
    id: 'launched',
    status: 'done',
    period: 'Запущено',
    date: '2025',
    title: 'Ядро платформы',
    color: '#22c55e',
    items: [
      { label: '6 модулей контента', desc: 'Аватар, Reels, посты, карусели, SEO-статьи, репостинг — все форматы в одной системе' },
      { label: 'Единый контент-план', desc: 'Один источник идей разворачивается во все форматы автоматически' },
      { label: 'Мультитенантная архитектура', desc: 'Изолированные данные и настройки для каждого клиента' },
      { label: 'AI-онбординг', desc: 'Анализ tone of voice, ниши и аудитории при подключении клиента' },
      { label: 'BYOK и BYOB', desc: 'Клиент подключает свои ключи API и Telegram-бота для модерации' },
      { label: 'Human in the loop', desc: 'Контент проходит согласование перед публикацией — ничего не уходит без одобрения' },
      { label: 'SEO + GEO оптимизация', desc: 'Семантическое ядро, ключевые слова и геотаргетинг встроены в генерацию' },
      { label: 'Humanizer', desc: 'AI-тексты проходят обработку для естественного звучания и уникальности' },
    ],
  },
  {
    id: 'current',
    status: 'in-progress',
    period: 'В разработке',
    date: 'Q2 2026',
    title: 'Расширение рынков и форматов',
    color: '#f59e0b',
    items: [
      { label: 'Полный SEO-цикл', desc: 'Семантическое ядро, генерация статей, автопубликация на блог клиента' },
      { label: 'Мультиязычный SEO-модуль', desc: 'Статьи на нескольких языках с раздельной оптимизацией под каждый рынок' },
      { label: 'Автопостинг во все соцсети', desc: 'Instagram, LinkedIn, Telegram, TikTok — публикация без ручного труда' },
      { label: 'Публичный запуск prizma.to', desc: 'Открытый доступ, онбординг и первые клиенты' },
    ],
  },
  {
    id: 'q3',
    status: 'planned',
    period: 'Планируется',
    date: 'Q3 2026',
    title: 'AI-агенты: контроль качества',
    color: '#8b5cf6',
    items: [
      { label: 'Quality Gate Agent', desc: 'AI-проверка контента перед публикацией: факты, стиль, tone of voice' },
      { label: 'Аналитика постов', desc: 'Автосбор метрик: охваты, лайки, вовлечённость по каждому клиенту' },
      { label: 'Astro SSR блог', desc: 'Рендеринг клиентских блогов с идеальными Core Web Vitals' },
    ],
  },
  {
    id: 'q4',
    status: 'planned',
    period: 'Планируется',
    date: 'Q4 2026',
    title: 'Самообучающаяся система',
    color: '#ec4899',
    items: [
      { label: 'SEO Feedback Loop', desc: 'Мониторинг позиций, автодоработка статей и переиндексация по результатам' },
      { label: 'Content Performance Agent', desc: 'Анализ что работает у клиента, автокоррекция контент-плана' },
      { label: 'Кросс-модульная связность', desc: 'AI-агент синхронизирует нарратив между всеми форматами контента' },
    ],
  },
];

const statusConfig: Record<string, { label: string; icon: string }> = {
  'done':        { label: 'Готово',    icon: '✓' },
  'in-progress': { label: 'В работе', icon: '◉' },
  'planned':     { label: 'В планах', icon: '◎' },
};
---

<section class="roadmap" id="roadmap">
  <div class="section-wrap">
    <!-- Header -->
    <div class="roadmap-header reveal">
      <div class="roadmap-pill">
        <span class="pill-dot">◉</span>
        Roadmap 2025–2026
      </div>
      <h2>Куда движется PRIZMA</h2>
      <p class="roadmap-sub">От автоматизации контента к самообучающейся системе, которая сама улучшает результаты ваших публикаций</p>
    </div>

    <!-- Timeline -->
    <div class="timeline">
      {phases.map((phase, i) => (
        <div class="phase-row reveal" data-index={i} style={`--phase-color: ${phase.color};`}>
          <!-- Node -->
          <div class={`phase-node node-${phase.status}`}>
            <span class="node-icon">{statusConfig[phase.status].icon}</span>
          </div>

          <!-- Connector line -->
          {i < phases.length - 1 && (
            <div class={`connector connector-${phase.status}`}
              style={`--next-color: ${phases[i + 1].color};`}
            ></div>
          )}

          <!-- Card -->
          <div
            class={`phase-card phase-${phase.status}`}
            data-open={phase.status === 'in-progress' ? 'true' : 'false'}
          >
            <!-- Card header -->
            <div class="phase-header">
              <div class="phase-top-row">
                <span class="phase-date">{phase.date}</span>
                <span class="phase-status-label">{statusConfig[phase.status].label}</span>
                <div class="phase-spacer"></div>
                <div class="phase-chevron">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                </div>
              </div>
              <h3 class="phase-title">{phase.title}</h3>
            </div>

            <!-- Card body -->
            <div class="phase-body">
              <p class="phase-count">
                {phase.items.length} {phase.items.length > 4 ? 'фич' : phase.items.length > 1 ? 'фичи' : 'фича'}
              </p>
              <div class="phase-items">
                {phase.items.map((item, idx) => (
                  <div class="phase-item" style={`--item-delay: ${idx * 0.06}s`}>
                    <div class="item-dot"></div>
                    <div class="item-text">
                      <div class="item-label">{item.label}</div>
                      <div class="item-desc">{item.desc}</div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="roadmap-cta reveal">
      <div class="cta-text">
        <div class="cta-title">Хотите повлиять на приоритеты?</div>
        <div class="cta-desc">Напишите нам, какие функции важны для вас</div>
      </div>
      <a href="#contact" class="cta-btn">Связаться</a>
    </div>
  </div>
</section>

<style>
  .roadmap {
    position: relative;
    z-index: 1;
  }

  /* Header */
  .roadmap-header {
    max-width: 640px;
    margin: 0 auto 56px;
    text-align: center;
  }

  .roadmap-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    border-radius: 100px;
    border: 1px solid rgba(139,92,246,0.2);
    background: rgba(139,92,246,0.06);
    margin-bottom: 20px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #8b5cf6;
    font-family: monospace;
  }

  .pill-dot {
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.4; }
    50%      { opacity: 0.8; }
  }

  .roadmap-header h2 {
    font-size: 2.2rem;
    font-weight: 800;
    line-height: 1.15;
    margin: 0 0 12px;
    background: linear-gradient(135deg, #f0f0f5 30%, rgba(139,92,246,0.5));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .roadmap-sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.6;
    max-width: 480px;
    margin: 0 auto;
  }

  /* Timeline */
  .timeline {
    max-width: 560px;
    margin: 0 auto;
  }

  /* Phase row */
  .phase-row {
    position: relative;
    padding-left: 48px;
  }

  /* Node */
  .phase-node {
    position: absolute;
    left: 0;
    top: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid var(--phase-color);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    box-shadow: 0 0 20px color-mix(in srgb, var(--phase-color) 20%, transparent);
  }

  .node-icon {
    font-size: 14px;
    color: var(--phase-color);
    font-weight: 700;
  }

  .node-done {
    background: var(--phase-color);
  }

  .node-done .node-icon {
    color: #fff;
    font-size: 16px;
  }

  .node-in-progress {
    background: linear-gradient(135deg, color-mix(in srgb, var(--phase-color) 20%, transparent), color-mix(in srgb, var(--phase-color) 7%, transparent));
  }

  .node-planned {
    background: linear-gradient(135deg, color-mix(in srgb, var(--phase-color) 20%, transparent), color-mix(in srgb, var(--phase-color) 7%, transparent));
  }

  /* Connector line */
  .connector {
    position: absolute;
    left: 15px;
    top: 32px;
    width: 2px;
    bottom: -24px;
    z-index: 1;
  }

  .connector-done {
    background: linear-gradient(to bottom, var(--phase-color), color-mix(in srgb, var(--next-color) 27%, transparent));
  }

  .connector-in-progress,
  .connector-planned {
    background: linear-gradient(to bottom, color-mix(in srgb, var(--phase-color) 27%, transparent), color-mix(in srgb, var(--next-color) 14%, transparent));
  }

  /* Card */
  .phase-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px;
    cursor: pointer;
    margin-bottom: 24px;
    transition: all 0.3s ease;
    overflow: hidden;
  }

  .phase-card[data-open="true"] {
    background: color-mix(in srgb, var(--phase-color) 8%, transparent);
    border-color: color-mix(in srgb, var(--phase-color) 20%, transparent);
  }

  .phase-card:hover {
    background: rgba(255,255,255,0.04);
  }

  .phase-card[data-open="true"]:hover {
    background: color-mix(in srgb, var(--phase-color) 10%, transparent);
  }

  /* Header */
  .phase-header {
    padding: 20px 24px;
  }

  .phase-top-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }

  .phase-date {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--phase-color);
    background: color-mix(in srgb, var(--phase-color) 10%, transparent);
    padding: 4px 10px;
    border-radius: 6px;
    font-family: monospace;
  }

  .phase-status-label {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--phase-color);
    opacity: 0.7;
  }

  .phase-spacer { flex: 1; }

  .phase-chevron {
    color: rgba(255,255,255,0.4);
    transition: transform 0.3s ease;
  }

  .phase-card[data-open="true"] .phase-chevron {
    transform: rotate(180deg);
  }

  .phase-title {
    font-size: 18px;
    font-weight: 700;
    color: #f0f0f5;
    margin: 0;
    line-height: 1.3;
  }

  /* Body (collapsible) */
  .phase-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s ease;
  }

  .phase-card[data-open="true"] .phase-body {
    max-height: 800px;
  }

  .phase-count {
    font-size: 12px;
    color: rgba(255,255,255,0.35);
    margin: 0 0 16px;
    padding: 0 24px;
    font-family: monospace;
  }

  /* Items */
  .phase-items {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 0 24px 24px;
  }

  @keyframes fadeSlideIn {
    from { opacity: 0; transform: translateX(-8px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .phase-card[data-open="true"] .phase-item {
    animation: fadeSlideIn 0.4s ease forwards var(--item-delay);
    opacity: 0;
  }

  .phase-item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }

  .item-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--phase-color);
    margin-top: 7px;
    flex-shrink: 0;
    opacity: 0.6;
  }

  .item-text {
    display: flex;
    flex-direction: column;
  }

  .item-label {
    font-size: 14px;
    font-weight: 600;
    color: #e0e0e8;
    line-height: 1.4;
  }

  .item-desc {
    font-size: 13px;
    color: rgba(255,255,255,0.4);
    line-height: 1.5;
    margin-top: 2px;
  }

  /* CTA */
  .roadmap-cta {
    max-width: 560px;
    margin: 40px auto 0;
    padding-left: 48px;
  }

  .roadmap-cta > * {
    padding: 20px 24px;
    border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.06);
    background: linear-gradient(135deg, rgba(139,92,246,0.05), rgba(236,72,153,0.03));
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* override: make cta itself the flex container */
  .roadmap-cta {
    padding: 20px 24px 20px 72px;
    border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.06);
    background: linear-gradient(135deg, rgba(139,92,246,0.05), rgba(236,72,153,0.03));
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .cta-text { flex: 1; min-width: 200px; }

  .cta-title {
    font-size: 14px;
    font-weight: 600;
    color: #e0e0e8;
    margin-bottom: 4px;
  }

  .cta-desc {
    font-size: 13px;
    color: rgba(255,255,255,0.4);
  }

  .cta-btn {
    padding: 10px 20px;
    border-radius: 10px;
    background: linear-gradient(135deg, #8b5cf6, #6d28d9);
    color: #fff;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 2px 12px rgba(139,92,246,0.3);
    white-space: nowrap;
  }

  .cta-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(139,92,246,0.4);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .phase-row { padding-left: 40px; }
    .phase-node { width: 26px; height: 26px; }
    .connector { left: 12px; }
    .roadmap-cta { padding-left: 40px; flex-direction: column; text-align: center; }
    .roadmap-header h2 { font-size: 1.7rem; }
  }
</style>

<script>
  document.querySelectorAll('.phase-card').forEach(card => {
    card.addEventListener('click', () => {
      const isOpen = card.getAttribute('data-open') === 'true';
      card.setAttribute('data-open', isOpen ? 'false' : 'true');
    });
  });
</script>
