---
interface Props {
  t: Record<string, any>;
}
const { t } = Astro.props;

const cards = [
  {
    tag: t.modules.items[0].name,
    tagClass: 'tag-post',
    title: t.lang === 'ru' ? 'Как эксперту быть в ленте каждый день без копирайтера' : t.lang === 'de' ? 'Wie Experten täglich präsent sind — ohne Texter' : 'How experts stay visible every day — without a copywriter',
    meta: t.lang === 'ru' ? 'Пост · Instagram / LinkedIn' : t.lang === 'de' ? 'Post · Instagram / LinkedIn' : 'Post · Instagram / LinkedIn',
    gradient: 'linear-gradient(135deg, #1a1040, #2d1f5e)',
    image: '/showcase-post.png',
  },
  {
    tag: t.modules.items[1].name,
    tagClass: 'tag-reel',
    title: t.lang === 'ru' ? 'Автопостинг для экспертов: как это работает' : t.lang === 'de' ? 'Automatisches Posting für Experten: So geht\'s' : 'Automated posting for experts: how it works',
    meta: t.lang === 'ru' ? 'Рилс · 30 сек' : t.lang === 'de' ? 'Reel · 30 Sek.' : 'Reel · 30 sec',
    gradient: 'linear-gradient(135deg, #1e3a5f, #0e4155)',
    image: null,
  },
  {
    tag: t.modules.items[2].name,
    tagClass: 'tag-carousel',
    title: t.lang === 'ru' ? 'Слайды, которые объясняют лучше, чем длинный пост' : t.lang === 'de' ? 'Slides, die mehr sagen als ein langer Post' : 'Slides that explain more than a long post',
    meta: t.lang === 'ru' ? 'Карусель · Instagram / LinkedIn' : t.lang === 'de' ? 'Karussell · Instagram / LinkedIn' : 'Carousel · Instagram / LinkedIn',
    gradient: 'linear-gradient(135deg, #14332a, #1a4037)',
    image: null,
    carousel: ['/showcase-carousel-1.png', '/showcase-carousel-2.png', '/showcase-carousel-3.png'],
  },
];
---

<section class="showcase-section" id="cases">
  <div class="section-wrap">
    <h2 class="reveal">{t.showcase.heading}</h2>
    <p class="section-subtitle reveal">{t.showcase.subtitle}</p>

    <div class="showcase-grid" data-stagger>
      {cards.map((card, cardIndex) => (
        <div class="showcase-card glass-card">
          <div class="showcase-preview" style={`background: ${card.gradient};`}>
            {card.image
              ? <img src={card.image} alt={card.tag} class="showcase-preview-img" />
              : card.carousel
              ? (
                <div class="carousel-wrapper" data-carousel={cardIndex}>
                  {card.carousel.map((src, i) => (
                    <img src={src} alt={`${card.tag} ${i+1}`} class={`showcase-preview-img carousel-slide${i === 0 ? ' active' : ''}`} data-slide={i} />
                  ))}
                  <button class="carousel-btn carousel-prev" data-dir="prev">‹</button>
                  <button class="carousel-btn carousel-next" data-dir="next">›</button>
                  <div class="carousel-dots">
                    {card.carousel.map((_, i) => (
                      <span class={`carousel-dot${i === 0 ? ' active' : ''}`} data-dot={i}></span>
                    ))}
                  </div>
                </div>
              )
              : <div class="showcase-preview-content"><span class="showcase-preview-text">{card.tag}</span></div>
            }
            <span class={`showcase-tag ${card.tagClass}`}>{card.tag}</span>
          </div>
          <div class="showcase-info">
            <div class="showcase-title">{card.title}</div>
            <div class="showcase-meta">{card.meta}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .showcase-section {
    position: relative;
    z-index: 1;
  }

  .showcase-section h2 {
    text-align: center;
  }

  .showcase-section .section-subtitle {
    text-align: center;
    margin: 16px auto 60px;
  }

  .showcase-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .showcase-card {
    overflow: hidden;
    padding: 0;
  }

  .showcase-card:hover {
    transform: translateY(-6px);
  }

  .showcase-preview {
    height: 200px;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .showcase-preview-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .carousel-wrapper {
    position: absolute;
    inset: 0;
  }

  .carousel-slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .carousel-slide.active {
    opacity: 1;
  }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0,0,0,0.5);
    border: none;
    color: #fff;
    font-size: 1.4rem;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    cursor: pointer;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    transition: background 0.2s;
  }

  .carousel-btn:hover { background: rgba(0,0,0,0.8); }
  .carousel-prev { left: 8px; }
  .carousel-next { right: 8px; }

  .carousel-dots {
    position: absolute;
    bottom: 8px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 5px;
    z-index: 10;
  }

  .carousel-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255,255,255,0.4);
    transition: background 0.2s;
  }

  .carousel-dot.active { background: #fff; }

  .showcase-preview-content {
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .showcase-preview-text {
    font-family: 'Unbounded', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--text-secondary);
  }

  .showcase-tag {
    position: absolute;
    bottom: 12px;
    left: 12px;
    padding: 4px 12px;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .tag-post    { background: rgba(99, 102, 241, 0.3);  color: #A5B4FC; }
  .tag-reel    { background: rgba(236, 72, 153, 0.3); color: #F9A8D4; }
  .tag-carousel { background: rgba(6, 182, 212, 0.3);  color: #67E8F9; }

  .showcase-info {
    padding: 20px 24px;
  }

  .showcase-title {
    font-weight: 600;
    font-size: 1rem;
    color: var(--text-primary);
    margin-bottom: 6px;
  }

  .showcase-meta {
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  @media (max-width: 900px) {
    .showcase-grid { grid-template-columns: 1fr; max-width: 480px; margin: 0 auto; }
  }
</style>

<script>
  document.querySelectorAll('.carousel-wrapper').forEach(wrapper => {
    const slides = wrapper.querySelectorAll('.carousel-slide');
    const dots = wrapper.querySelectorAll('.carousel-dot');
    let current = 0;

    function goTo(index) {
      slides[current].classList.remove('active');
      dots[current].classList.remove('active');
      current = (index + slides.length) % slides.length;
      slides[current].classList.add('active');
      dots[current].classList.add('active');
    }

    wrapper.querySelector('.carousel-prev')?.addEventListener('click', () => goTo(current - 1));
    wrapper.querySelector('.carousel-next')?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
  });
</script>
