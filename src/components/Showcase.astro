---
interface Props {
  t: Record<string, any>;
}
const { t } = Astro.props;

const cards = [
  {
    type: 'post',
    tag: t.modules.items[0].name,
    tagClass: 'tag-post',
    username: 'prizma.to',
    image: '/showcase-post.png',
    caption: t.lang === 'ru'
      ? 'Контент-план готов. Посты написаны. Публикации запланированы. Ты просто занималась своим делом. Именно так работает PRIZMA.'
      : t.lang === 'de'
      ? 'Content-Plan fertig. Posts geschrieben. Veröffentlichungen geplant. Genau so funktioniert PRIZMA.'
      : 'Content plan ready. Posts written. Publications scheduled. That\'s exactly how PRIZMA works.',
    hashtags: t.lang === 'ru' ? '#контентмаркетинг #автоматизация #личныйбренд' : t.lang === 'de' ? '#contentmarketing #automatisierung #personalbrand' : '#contentmarketing #automation #personalbrand',
    likes: '2,4K',
  },
  {
    type: 'reel',
    tag: t.modules.items[1].name,
    tagClass: 'tag-reel',
    username: 'prizma.to',
    video: '/showcase-reel.mp4',
    caption: t.lang === 'ru'
      ? 'Не копируем чужие тренды, а создаём контент из твоей экспертности. PRIZMA пишет сценарий и генерирует рилс, который продвигает именно тебя.'
      : t.lang === 'de'
      ? 'Wir kopieren keine fremden Trends, sondern erstellen Content aus deiner Expertise. PRIZMA schreibt das Skript und generiert ein Reel, das dich als Experten positioniert.'
      : 'No copying other people\'s trends. PRIZMA creates content from your expertise, writes the script and generates a reel that positions you as the expert.',
    hashtags: t.lang === 'ru' ? '#рилс #автоматизация #prizma' : t.lang === 'de' ? '#reels #automatisierung #prizma' : '#reels #automation #prizma',
    likes: '5,1K',
  },
  {
    type: 'carousel',
    tag: t.modules.items[2].name,
    tagClass: 'tag-carousel',
    username: 'prizma.to',
    carousel: t.lang === 'de'
      ? ['/de-carousel-1.png', '/de-carousel-2.png', '/de-carousel-3.png']
      : t.lang === 'en'
      ? ['/en-carousel-1.png', '/en-carousel-2.png', '/en-carousel-3.png']
      : ['/showcase-carousel-2.png', '/showcase-carousel-1.png', '/showcase-carousel-3.png'],
    caption: t.lang === 'ru'
      ? 'Слайды, которые объясняют лучше, чем длинный пост! Почему карусели в Instagram и LinkedIn получают больше охватов и сохранений, чем обычные посты. Как эксперту быстро создавать слайды по своей теме — без дизайнера и сложных инструментов.'
      : t.lang === 'de'
      ? 'Karussell-Slides, die besser erklären als ein langer Post! Warum Karussell-Posts auf Instagram und LinkedIn mehr Reichweite und Saves bekommen als normale Beiträge. Wie Experten schnell Karussells zu ihrem Thema erstellen — ohne Designer, ohne komplizierte Tools.'
      : 'Slides that explain better than a long post! Why carousels on Instagram and LinkedIn get more reach and saves than regular posts. How experts can quickly create slides on their topic — no designer, no complicated tools.',
    hashtags: t.lang === 'ru' ? '#контентмаркетинг #нейросети #личныйбренд' : t.lang === 'de' ? '#contentmarketing #ki #personalbrand' : '#contentmarketing #ai #personalbrand',
    likes: '3,7K',
  },
];
---

<section class="showcase-section" id="cases">
  <div class="section-wrap">
    <h2 class="reveal">{t.showcase.heading}</h2>
    <p class="section-subtitle reveal">{t.showcase.subtitle}</p>

    <div class="showcase-grid" data-stagger>
      {cards.map((card, i) => (
        <div class="insta-card glass-card">
          <!-- Header -->
          <div class="insta-header">
            <div class="insta-avatar">P</div>
            <div class="insta-user">
              <span class="insta-username">{card.username}</span>
              <span class="insta-platform">Instagram</span>
            </div>
            <span class={`insta-tag ${card.tagClass}`}>{card.tag}</span>
          </div>

          <!-- Media -->
          <div class="insta-media">
            {card.type === 'post' && card.image && (
              <img src={card.image} alt={card.tag} class="insta-img" />
            )}
            {card.type === 'reel' && card.video && (
              <video
                class="insta-video"
                src={card.video}
                muted
                loop
                playsinline
                preload="metadata"
                poster=""
              />
            )}
            {card.type === 'carousel' && card.carousel && (
              <div class="insta-carousel" data-idx={i}>
                <div class="insta-progress">
                  {card.carousel.map((_, j) => (
                    <div class={`insta-progress-bar${j === 0 ? ' active' : ''}`}></div>
                  ))}
                </div>
                {card.carousel.map((src, j) => (
                  <img src={src} alt={`slide ${j+1}`} class={`insta-img insta-slide${j === 0 ? ' active' : ''}`} data-slide={j} />
                ))}
                <div class="insta-tap-l" data-dir="-1"></div>
                <div class="insta-tap-r" data-dir="1"></div>
              </div>
            )}
          </div>

          <!-- Actions -->
          <div class="insta-actions">
            <span class="insta-action">♡</span>
            <span class="insta-action">💬</span>
            <span class="insta-action">↗</span>
          </div>

          <!-- Likes + Caption -->
          <div class="insta-body">
            <div class="insta-likes">{card.likes} {t.lang === 'ru' ? 'отметок «Нравится»' : t.lang === 'de' ? 'Gefällt mir' : 'likes'}</div>
            <div class="insta-caption">
              {card.caption}
            </div>
            <div class="insta-hashtags">{card.hashtags}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .showcase-section {
    position: relative;
    z-index: 1;
  }
  .showcase-section h2 { text-align: center; }
  .showcase-section .section-subtitle {
    text-align: center;
    margin: 16px auto 60px;
  }

  .showcase-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    align-items: stretch;
  }

  .insta-card {
    padding: 0;
    overflow: hidden;
    border-radius: 16px;
    display: flex;
    flex-direction: column;
  }

  /* Header */
  .insta-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
  }
  .insta-avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: linear-gradient(135deg, #8B5CF6, #06B6D4);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.85rem;
    color: #fff;
    flex-shrink: 0;
    border: 2px solid rgba(139,92,246,0.4);
  }
  .insta-user {
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .insta-username {
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--text-primary);
  }
  .insta-platform {
    font-size: 0.72rem;
    color: var(--text-dim);
  }
  .insta-tag {
    padding: 3px 10px;
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  .tag-post     { background: rgba(99,102,241,0.25); color: #A5B4FC; }
  .tag-reel     { background: rgba(236,72,153,0.25); color: #F9A8D4; }
  .tag-carousel { background: rgba(6,182,212,0.25);  color: #67E8F9; }

  /* Media */
  .insta-media {
    width: 100%;
    aspect-ratio: 4 / 5;
    position: relative;
    overflow: hidden;
    background: #0a0a0f;
  }
  .insta-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Reel video */
  .insta-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Carousel */
  .insta-carousel {
    position: relative;
    width: 100%;
    height: 100%;
  }
  .insta-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.35s ease;
  }
  .insta-slide.active { opacity: 1; }

  /* Progress bar */
  .insta-progress {
    position: absolute;
    top: 8px;
    left: 8px;
    right: 8px;
    display: flex;
    gap: 4px;
    z-index: 6;
  }
  .insta-progress-bar {
    flex: 1;
    height: 2px;
    border-radius: 2px;
    background: rgba(255,255,255,0.3);
    transition: background 0.2s;
  }
  .insta-progress-bar.active { background: rgba(255,255,255,0.95); }

  /* Tap zones */
  .insta-tap-l, .insta-tap-r {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 40%;
    z-index: 5;
    cursor: pointer;
  }
  .insta-tap-l { left: 0; }
  .insta-tap-r { right: 0; }

  /* Actions */
  .insta-actions {
    display: flex;
    gap: 14px;
    padding: 10px 14px 4px;
  }
  .insta-action {
    font-size: 1.3rem;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity 0.2s;
  }
  .insta-action:hover { opacity: 1; }

  /* Body */
  .insta-body {
    padding: 0 14px 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }
  .insta-likes {
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--text-primary);
    margin-bottom: 6px;
  }
  .insta-caption {
    font-size: 0.83rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: 4px;
  }
  .insta-caption-user {
    font-weight: 700;
    color: var(--text-primary);
  }
  .insta-hashtags {
    font-size: 0.8rem;
    color: #A5B4FC;
    margin-top: 4px;
  }

  @media (max-width: 900px) {
    .showcase-grid { grid-template-columns: 1fr; max-width: 420px; margin: 0 auto; }
  }
</style>

<script>
  // Auto-play reel video when visible
  document.querySelectorAll('.insta-video').forEach(video => {
    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          (video as HTMLVideoElement).play().catch(() => {});
        } else {
          (video as HTMLVideoElement).pause();
        }
      });
    }, { threshold: 0.3 });
    observer.observe(video);
  });

  document.querySelectorAll('.insta-carousel').forEach(carousel => {
    const slides = carousel.querySelectorAll('.insta-slide');
    const bars = carousel.querySelectorAll('.insta-progress-bar');
    let cur = 0;

    function goTo(n: number) {
      slides[cur].classList.remove('active');
      bars[cur].classList.remove('active');
      cur = (n + slides.length) % slides.length;
      slides[cur].classList.add('active');
      bars[cur].classList.add('active');
    }

    // Tap zones
    carousel.querySelector('.insta-tap-l')?.addEventListener('click', () => goTo(cur - 1));
    carousel.querySelector('.insta-tap-r')?.addEventListener('click', () => goTo(cur + 1));

    // Swipe support
    let touchStartX = 0;
    carousel.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });
    carousel.addEventListener('touchend', (e: TouchEvent) => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) goTo(diff > 0 ? cur + 1 : cur - 1);
    }, { passive: true });
  });
</script>
