---
interface Props {
  t: Record<string, any>;
}
const { t } = Astro.props;

const cards = [
  {
    type: 'post',
    tag: t.modules.items[0].name,
    tagClass: 'tag-post',
    username: 'prizma.to',
    image: '/showcase-post.png',
    caption: t.lang === 'ru'
      ? 'Контент-план готов. Посты написаны. Публикации запланированы. Ты просто занималась своим делом. Именно так работает PRIZMA.'
      : t.lang === 'de'
      ? 'Content-Plan fertig. Posts geschrieben. Veröffentlichungen geplant. Genau so funktioniert PRIZMA.'
      : 'Content plan ready. Posts written. Publications scheduled. That\'s exactly how PRIZMA works.',
    hashtags: t.lang === 'ru' ? '#контентмаркетинг #автоматизация #личныйбренд' : t.lang === 'de' ? '#contentmarketing #automatisierung #personalbrand' : '#contentmarketing #automation #personalbrand',
    likes: '2,4K',
  },
  {
    type: 'reel',
    tag: t.modules.items[1].name,
    tagClass: 'tag-reel',
    username: 'prizma.to',
    image: null,
    caption: t.lang === 'ru'
      ? 'С PRIZMA не нужно вставать перед камерой каждый день. Твой аватар публикует контент сам.'
      : t.lang === 'de'
      ? 'Mit PRIZMA musst du dich nicht täglich vor die Kamera setzen.'
      : 'With PRIZMA, no camera needed. Your avatar publishes content on its own.',
    hashtags: t.lang === 'ru' ? '#рилс #автоматизация #prizma' : t.lang === 'de' ? '#reels #automatisierung #prizma' : '#reels #automation #prizma',
    likes: '5,1K',
  },
  {
    type: 'carousel',
    tag: t.modules.items[2].name,
    tagClass: 'tag-carousel',
    username: 'prizma.to',
    carousel: ['/showcase-carousel-2.png', '/showcase-carousel-1.png', '/showcase-carousel-3.png'],
    caption: t.lang === 'ru'
      ? 'Длинные тексты пугают, а карусели влюбляют! Самый простой способ упаковать экспертность в понятные смыслы.'
      : t.lang === 'de'
      ? 'Lange Texte schrecken ab, Karussells begeistern! Der einfachste Weg, Expertise in klare Botschaften zu verpacken.'
      : 'Long texts scare, carousels captivate! The easiest way to pack your expertise into clear slides.',
    hashtags: t.lang === 'ru' ? '#контентмаркетинг #нейросети #личныйбренд' : t.lang === 'de' ? '#contentmarketing #ki #personalbrand' : '#contentmarketing #ai #personalbrand',
    likes: '3,7K',
  },
];
---

<section class="showcase-section" id="cases">
  <div class="section-wrap">
    <h2 class="reveal">{t.showcase.heading}</h2>
    <p class="section-subtitle reveal">{t.showcase.subtitle}</p>

    <div class="showcase-grid" data-stagger>
      {cards.map((card, i) => (
        <div class="insta-card glass-card">
          <!-- Header -->
          <div class="insta-header">
            <div class="insta-avatar">P</div>
            <div class="insta-user">
              <span class="insta-username">{card.username}</span>
              <span class="insta-platform">Instagram</span>
            </div>
            <span class={`insta-tag ${card.tagClass}`}>{card.tag}</span>
          </div>

          <!-- Media -->
          <div class="insta-media">
            {card.type === 'post' && card.image && (
              <img src={card.image} alt={card.tag} class="insta-img" />
            )}
            {card.type === 'reel' && (
              <div class="insta-reel-placeholder">
                <div class="reel-icon">▶</div>
                <span class="reel-coming">{t.lang === 'ru' ? 'Рилс скоро' : t.lang === 'de' ? 'Reel bald' : 'Reel coming soon'}</span>
              </div>
            )}
            {card.type === 'carousel' && card.carousel && (
              <div class="insta-carousel" data-idx={i}>
                {card.carousel.map((src, j) => (
                  <img src={src} alt={`slide ${j+1}`} class={`insta-img insta-slide${j === 0 ? ' active' : ''}`} data-slide={j} />
                ))}
                <button class="insta-arr insta-arr-l" data-dir="-1">‹</button>
                <button class="insta-arr insta-arr-r" data-dir="1">›</button>
                <div class="insta-dots">
                  {card.carousel.map((_, j) => (
                    <span class={`insta-dot${j === 0 ? ' active' : ''}`}></span>
                  ))}
                </div>
              </div>
            )}
          </div>

          <!-- Actions -->
          <div class="insta-actions">
            <span class="insta-action">♡</span>
            <span class="insta-action">💬</span>
            <span class="insta-action">↗</span>
          </div>

          <!-- Likes + Caption -->
          <div class="insta-body">
            <div class="insta-likes">{card.likes} {t.lang === 'ru' ? 'отметок «Нравится»' : t.lang === 'de' ? 'Gefällt mir' : 'likes'}</div>
            <div class="insta-caption">
              <span class="insta-caption-user">{card.username}</span> {card.caption}
            </div>
            <div class="insta-hashtags">{card.hashtags}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .showcase-section {
    position: relative;
    z-index: 1;
  }
  .showcase-section h2 { text-align: center; }
  .showcase-section .section-subtitle {
    text-align: center;
    margin: 16px auto 60px;
  }

  .showcase-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    align-items: start;
  }

  .insta-card {
    padding: 0;
    overflow: hidden;
    border-radius: 16px;
  }

  /* Header */
  .insta-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
  }
  .insta-avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: linear-gradient(135deg, #8B5CF6, #06B6D4);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.85rem;
    color: #fff;
    flex-shrink: 0;
    border: 2px solid rgba(139,92,246,0.4);
  }
  .insta-user {
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .insta-username {
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--text-primary);
  }
  .insta-platform {
    font-size: 0.72rem;
    color: var(--text-dim);
  }
  .insta-tag {
    padding: 3px 10px;
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  .tag-post     { background: rgba(99,102,241,0.25); color: #A5B4FC; }
  .tag-reel     { background: rgba(236,72,153,0.25); color: #F9A8D4; }
  .tag-carousel { background: rgba(6,182,212,0.25);  color: #67E8F9; }

  /* Media */
  .insta-media {
    width: 100%;
    aspect-ratio: 1 / 1;
    position: relative;
    overflow: hidden;
    background: #0a0a0f;
  }
  .insta-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Reel placeholder */
  .insta-reel-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1e3a5f, #0e4155);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }
  .reel-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(255,255,255,0.12);
    border: 2px solid rgba(255,255,255,0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    color: #fff;
    padding-left: 4px;
  }
  .reel-coming {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.5);
    letter-spacing: 1px;
  }

  /* Carousel */
  .insta-carousel {
    position: relative;
    width: 100%;
    height: 100%;
  }
  .insta-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.35s ease;
  }
  .insta-slide.active { opacity: 1; }

  .insta-arr {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.85);
    border: none;
    color: #111;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    font-size: 1rem;
    cursor: pointer;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    line-height: 1;
  }
  .insta-arr:hover { background: #fff; }
  .insta-arr-l { left: 10px; }
  .insta-arr-r { right: 10px; }

  .insta-dots {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 5px;
    z-index: 5;
  }
  .insta-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255,255,255,0.4);
    transition: background 0.2s;
  }
  .insta-dot.active { background: #fff; }

  /* Actions */
  .insta-actions {
    display: flex;
    gap: 14px;
    padding: 10px 14px 4px;
  }
  .insta-action {
    font-size: 1.3rem;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity 0.2s;
  }
  .insta-action:hover { opacity: 1; }

  /* Body */
  .insta-body {
    padding: 0 14px 16px;
  }
  .insta-likes {
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--text-primary);
    margin-bottom: 6px;
  }
  .insta-caption {
    font-size: 0.83rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: 4px;
  }
  .insta-caption-user {
    font-weight: 700;
    color: var(--text-primary);
  }
  .insta-hashtags {
    font-size: 0.8rem;
    color: #A5B4FC;
    margin-top: 4px;
  }

  @media (max-width: 900px) {
    .showcase-grid { grid-template-columns: 1fr; max-width: 420px; margin: 0 auto; }
  }
</style>

<script>
  document.querySelectorAll('.insta-carousel').forEach(carousel => {
    const slides = carousel.querySelectorAll('.insta-slide');
    const dots = carousel.querySelectorAll('.insta-dot');
    let cur = 0;

    function goTo(n) {
      slides[cur].classList.remove('active');
      dots[cur].classList.remove('active');
      cur = (n + slides.length) % slides.length;
      slides[cur].classList.add('active');
      dots[cur].classList.add('active');
    }

    carousel.querySelector('.insta-arr-l')?.addEventListener('click', () => goTo(cur - 1));
    carousel.querySelector('.insta-arr-r')?.addEventListener('click', () => goTo(cur + 1));
    dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));
  });
</script>
