---
interface Props {
  t: Record<string, any>;
}
const { t } = Astro.props;

const reviews = t.testimonials.reviews || [];

const starSvg = `<svg width="18" height="18" viewBox="0 0 20 20" fill="#F59E0B"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.33L10 13.28l-4.77 2.51.91-5.33L2.27 6.62l5.34-.78z"/></svg>`;
---

<section id="reviews">
  <div class="section-wrap">
    <h2 class="reveal">{t.testimonials.heading}</h2>

    <div class="testimonials-grid" data-stagger>
      {reviews.map(review => (
        <div class="testimonial-card glass-card">
          <span class="quote-mark gradient-text">&ldquo;</span>
          <div class="stars" set:html={starSvg.repeat(5)} />
          <p class="review-text">{review.text}</p>
          <div class="review-author">
            {review.logo
              ? <img src={review.logo} alt={review.name} class="review-avatar review-avatar-logo" width="48" height="48" loading="lazy" />
              : <div class="review-avatar" style={`background: ${review.gradient};`}>{review.initials}</div>
            }
            <div>
              <div class="review-name">{review.name}</div>
              <div class="review-role">{review.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #reviews h2 {
    text-align: center;
    margin-bottom: 60px;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .testimonial-card {
    padding: 36px 28px;
  }

  .quote-mark {
    font-size: 3.5rem;
    line-height: 1;
    display: block;
    margin-bottom: 8px;
    font-family: Georgia, serif;
  }

  .stars {
    display: flex;
    gap: 3px;
    margin-bottom: 16px;
  }

  .review-text {
    font-size: 1rem;
    line-height: 1.7;
    color: #D1D5DB;
    margin-bottom: 24px;
    font-style: italic;
  }

  .review-author {
    display: flex;
    align-items: center;
    gap: 14px;
    border-top: 1px solid var(--border-glass);
    padding-top: 20px;
  }

  .review-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.95rem;
    color: #fff;
    flex-shrink: 0;
  }
  .review-avatar-logo {
    object-fit: contain;
    background: #fff;
    padding: 4px;
  }

  .review-name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-primary);
  }

  .review-role {
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-top: 2px;
  }

  @media (max-width: 900px) {
    .testimonials-grid { grid-template-columns: 1fr; max-width: 480px; margin: 0 auto; }
  }
</style>
